{
  "id": "tool-failure-containment",
  "title": "Tool Failure Containment",
  "ownerArea": "agent-tool-runtime",
  "description": "Verify deterministic tool errors, blocked execution, and timeouts are attributed to tool runtime evidence while gateway and command paths remain usable.",
  "processRoles": [
    "gateway",
    "command-tree",
    "agent-process",
    "tool-runtime",
    "mock-provider"
  ],
  "resourcePrimaryRole": "tool-runtime",
  "thresholds": {
    "gatewayReadyMs": 30000,
    "statusMs": 10000,
    "execDangerousCommandBlocked": 1,
    "execOutputTruncated": 1,
    "execTimeoutMs": 15000,
    "execProcessLeaks": 0,
    "peakRssMb": 900
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 850,
      "maxCpuPercent": 250
    },
    "tool-runtime": {
      "peakRssMb": 500,
      "maxCpuPercent": 200
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": false,
    "expectedSpans": [
      "tool.error",
      "tool.timeout"
    ]
  },
  "purposes": [
    "diagnostic",
    "regression"
  ],
  "requirements": [
    {
      "id": "failure-attribution",
      "states": [
        "exec-tool-user"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "execDangerousCommandBlocked",
        "execOutputTruncated",
        "execTimeoutMs",
        "execProcessLeaks",
        "statusMs"
      ]
    }
  ]
}
