{
  "id": "cron-runtime",
  "title": "Cron Runtime",
  "ownerArea": "cron-runtime",
  "description": "Exercise OpenClaw cron CLI, run-now execution, run history, trigger attribution, and post-cron gateway health in a disposable env.",
  "processRoles": [
    "gateway",
    "command-tree",
    "agent-process",
    "cron-runtime",
    "mock-provider"
  ],
  "resourcePrimaryRole": "cron-runtime",
  "thresholds": {
    "gatewayReadyMs": 30000,
    "statusMs": 10000,
    "cronRegisterMs": 10000,
    "cronRunMs": 60000,
    "cronRunCompleted": 1,
    "cronTriggerAttributed": 1,
    "peakRssMb": 900
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 850,
      "maxCpuPercent": 250
    },
    "cron-runtime": {
      "peakRssMb": 500,
      "maxCpuPercent": 200
    },
    "command-tree": {
      "peakRssMb": 900,
      "maxCpuPercent": 300
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": false,
    "expectedSpans": [
      "cron.add",
      "cron.run",
      "cron.runs"
    ]
  },
  "purposes": [
    "diagnostic",
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "run-now",
      "states": [
        "cron-user"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "cronRegisterMs",
        "cronRunMs",
        "cronRunCompleted",
        "cronTriggerAttributed",
        "statusMs"
      ]
    }
  ]
}
