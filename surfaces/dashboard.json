{
  "id": "dashboard",
  "title": "Dashboard",
  "ownerArea": "control-ui",
  "description": "Verify dashboard command output, websocket entry, and post-dashboard gateway health.",
  "processRoles": [
    "gateway",
    "command-tree",
    "dashboard-cli"
  ],
  "thresholds": {
    "dashboardConnectMs": 10000,
    "gatewayReadyMs": 30000,
    "statusMs": 10000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 800,
      "maxCpuPercent": 250
    },
    "dashboard-cli": {
      "peakRssMb": 500,
      "maxCpuPercent": 200
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": false,
    "expectedSpans": [
      "dashboard.url",
      "gateway.websocket"
    ]
  },
  "purposes": [
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "fresh"
      ],
      "targetKinds": [
        "npm",
        "channel",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "dashboardConnectMs",
        "gatewayReadyMs",
        "statusMs",
        "websocketDisconnects"
      ]
    }
  ]
}
