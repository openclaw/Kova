{
  "id": "mcp-tool-call",
  "title": "MCP Tool Call",
  "ownerArea": "mcp-runtime",
  "description": "Start OpenClaw's MCP stdio bridge, list tools, call a deterministic safe tool, call an invalid tool, and verify the bridge exits cleanly.",
  "processRoles": [
    "gateway",
    "command-tree",
    "mcp-runtime",
    "tool-runtime"
  ],
  "resourcePrimaryRole": "mcp-runtime",
  "thresholds": {
    "gatewayReadyMs": 30000,
    "statusMs": 10000,
    "mcpInitializeMs": 10000,
    "mcpToolsListMs": 10000,
    "mcpToolsCallMs": 10000,
    "mcpToolCallSucceeded": 1,
    "mcpToolCallErrorAttributed": 1,
    "mcpShutdownMs": 5000,
    "mcpToolCountMin": 1,
    "mcpProcessLeaks": 0,
    "peakRssMb": 900
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 850,
      "maxCpuPercent": 250
    },
    "mcp-runtime": {
      "peakRssMb": 500,
      "maxCpuPercent": 200
    },
    "tool-runtime": {
      "peakRssMb": 500,
      "maxCpuPercent": 200
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": false,
    "expectedSpans": [
      "mcp.runtime.start",
      "mcp.tools.call",
      "mcp.runtime.stop"
    ]
  },
  "purposes": [
    "diagnostic",
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "safe-tool-call",
      "states": [
        "mcp-tool-user"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "mcpInitializeMs",
        "mcpToolsListMs",
        "mcpToolsCallMs",
        "mcpToolCallSucceeded",
        "mcpToolCallErrorAttributed",
        "mcpShutdownMs",
        "mcpToolCountMin",
        "mcpProcessLeaks"
      ]
    }
  ]
}
