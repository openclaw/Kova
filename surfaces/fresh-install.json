{
  "id": "fresh-install",
  "title": "Fresh Install",
  "ownerArea": "runtime-startup",
  "description": "Create a disposable fresh OpenClaw home and verify gateway, plugins, models, logs, and baseline resource use.",
  "processRoles": [
    "gateway",
    "command-tree",
    "status-cli",
    "plugin-cli",
    "model-cli"
  ],
  "resourcePrimaryRole": "gateway",
  "thresholds": {
    "gatewayReadyMs": 30000,
    "statusMs": 10000,
    "peakRssMb": 1050
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 1050,
      "maxCpuPercent": 250
    },
    "status-cli": {
      "peakRssMb": 900,
      "maxCpuPercent": 200
    },
    "plugin-cli": {
      "peakRssMb": 900,
      "maxCpuPercent": 250
    },
    "model-cli": {
      "peakRssMb": 700,
      "maxCpuPercent": 250
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "gateway.ready",
      "config.normalize",
      "plugins.metadata.scan"
    ]
  },
  "purposes": [
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "corrupted-config",
        "fresh",
        "large-memory-session",
        "malformed-large-session-store",
        "missing-plugin-index",
        "old-config-keys",
        "onboarded-user",
        "plugin-index"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "gatewayReadyMs",
        "statusMs",
        "pluginsListMs",
        "modelsListMs",
        "peakRssMb"
      ]
    }
  ]
}
