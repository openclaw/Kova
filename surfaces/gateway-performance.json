{
  "id": "gateway-performance",
  "title": "Gateway Performance",
  "ownerArea": "gateway",
  "description": "Measure cold start, warm start, health latency, memory, CPU, and event-loop behavior for OpenClaw gateway usage.",
  "processRoles": [
    "gateway",
    "gateway-tree",
    "command-tree",
    "status-cli"
  ],
  "resourcePrimaryRole": "gateway",
  "thresholds": {
    "coldReadyMs": 30000,
    "warmReadyMs": 15000,
    "peakRssMb": 900,
    "postReadyHealthP95Ms": 1000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 800,
      "maxCpuPercent": 250
    },
    "gateway-tree": {
      "peakRssMb": 1000,
      "maxCpuPercent": 300
    },
    "status-cli": {
      "peakRssMb": 500,
      "maxCpuPercent": 200
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "gateway.startup",
      "health.ready",
      "eventLoop.delay"
    ]
  },
  "purposes": [
    "performance",
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "gateway-already-running",
        "many-bundled-plugins",
        "slow-filesystem",
        "stale-service-state"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "coldReadyMs",
        "warmReadyMs",
        "postReadyHealthP95Ms",
        "peakRssMb",
        "eventLoopMaxMs"
      ]
    }
  ]
}
