{
  "id": "bundled-runtime-deps",
  "title": "Bundled Runtime Dependencies",
  "ownerArea": "plugins",
  "description": "Validate cold and warm bundled plugin runtime dependency staging behavior.",
  "processRoles": [
    "gateway",
    "command-tree",
    "package-manager",
    "runtime-staging"
  ],
  "thresholds": {
    "coldReadyMs": 45000,
    "warmReadyMs": 20000,
    "runtimeDepsStagingMs": 30000,
    "warmRuntimeDepsRestageCount": 0,
    "warmRuntimeDepsStagingMs": 5000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 1050,
      "maxCpuPercent": 250
    },
    "runtime-staging": {
      "peakRssMb": 900,
      "maxCpuPercent": 350
    },
    "package-manager": {
      "peakRssMb": 900,
      "maxCpuPercent": 350
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "runtimeDeps.stage",
      "plugins.runtimeDeps",
      "plugins.runtimeDeps.install"
    ]
  },
  "purposes": [
    "plugin",
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "missing-plugin-index",
        "stale-runtime-deps"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "coldReadyMs",
        "warmReadyMs",
        "runtimeDepsStagingMs",
        "coldRuntimeDepsStagingMs",
        "warmRuntimeDepsStagingMs",
        "warmRuntimeDepsRestageCount",
        "runtimeDepsWarmReuseOk",
        "missingDependencyErrors"
      ]
    }
  ]
}
