{
  "id": "channel-model-turn-baseline",
  "title": "Channel Model Turn Baseline",
  "ownerArea": "OpenClaw",
  "description": "Validate that real inbound channel events run through the OpenClaw agent/model loop and produce expected channel responses for model-reachable delivery paths.",
  "processRoles": [
    "gateway",
    "command-tree",
    "agent-process",
    "mock-provider"
  ],
  "resourcePrimaryRole": "gateway",
  "thresholds": {
    "agentTurnMs": 45000,
    "preProviderMs": 10000,
    "providerFinalMs": 3000,
    "peakRssMb": 1024,
    "postReadyHealthP95Ms": 1000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 1024,
      "maxCpuPercent": 250
    },
    "mock-provider": {
      "peakRssMb": 250,
      "maxCpuPercent": 150
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "gateway.ready",
      "plugins.metadata.scan"
    ]
  },
  "purposes": [
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "mock-openai-provider"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "agentTurnMs",
        "agentTurnP95Ms",
        "agentTurnMaxMs",
        "coldPreProviderMs",
        "postReadyHealthP95Ms",
        "peakRssMb",
        "pluginLoadFailures"
      ]
    }
  ]
}
