{
  "id": "agent-gateway-rpc-turn",
  "title": "Agent CLI Gateway RPC Turn",
  "ownerArea": "agent-cli-gateway-client",
  "description": "Send messages through `openclaw agent` without `--local`, measuring the CLI client surface that crosses the Gateway agent RPC boundary. Direct Gateway/session user-path turns are measured by `gateway-session-send-turn`.",
  "processRoles": [
    "gateway",
    "command-tree",
    "agent-cli",
    "agent-process",
    "mock-provider"
  ],
  "resourcePrimaryRole": "agent-cli",
  "thresholds": {
    "agentTurnMs": 45000,
    "preProviderMs": 10000,
    "providerFinalMs": 3000,
    "peakRssMb": 900,
    "postReadyHealthP95Ms": 1000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 700,
      "maxCpuPercent": 250
    },
    "agent-cli": {
      "peakRssMb": 900,
      "maxCpuPercent": 300
    },
    "mock-provider": {
      "peakRssMb": 250,
      "maxCpuPercent": 150
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "gateway.ready",
      "plugins.metadata.scan"
    ]
  },
  "purposes": [
    "provider",
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "mock-openai-provider"
      ],
      "targetKinds": [
        "npm",
        "channel",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "agentTurnMs",
        "agentTurnP95Ms",
        "agentTurnMaxMs",
        "coldPreProviderMs",
        "postReadyHealthP95Ms",
        "peakRssMb",
        "pluginLoadFailures"
      ]
    }
  ]
}
