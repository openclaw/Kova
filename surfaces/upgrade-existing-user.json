{
  "id": "upgrade-existing-user",
  "title": "Existing User Upgrade",
  "ownerArea": "upgrade",
  "description": "Clone existing OpenClaw state, run the real upgrade path, and verify migrations, plugin indexes, runtime deps, gateway readiness, and diagnostics.",
  "processRoles": [
    "gateway",
    "command-tree",
    "runtime-management",
    "package-manager",
    "doctor-cli",
    "plugin-cli"
  ],
  "thresholds": {
    "upgradeMs": 120000,
    "gatewayReadyMs": 45000,
    "statusMs": 10000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 850,
      "maxCpuPercent": 250
    },
    "runtime-management": {
      "peakRssMb": 900,
      "maxCpuPercent": 350
    },
    "package-manager": {
      "peakRssMb": 900,
      "maxCpuPercent": 350
    },
    "doctor-cli": {
      "peakRssMb": 700,
      "maxCpuPercent": 300
    },
    "plugin-cli": {
      "peakRssMb": 600,
      "maxCpuPercent": 250
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "upgrade.apply",
      "doctor.fix",
      "plugins.index.migrate",
      "plugins.runtimeDeps"
    ]
  },
  "purposes": [
    "regression",
    "release",
    "upgrade"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "failed-upgrade",
        "old-release-2026-4-20-user",
        "old-release-2026-4-24-user",
        "old-release-user",
        "onboarded-user",
        "plugin-index",
        "stable-release-user"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "upgradeMs",
        "gatewayReadyMs",
        "statusMs",
        "pluginIndexPresent",
        "doctorFixMs"
      ]
    },
    {
      "id": "doctor-repair",
      "states": [
        "legacy-channel-config-doctor-2026-5-7",
        "legacy-core-config-doctor-2026-4-24",
        "legacy-plugin-config-doctor-2026-5-22",
        "legacy-provider-config-doctor-2026-5-7",
        "legacy-runtime-pin-doctor-2026-5-8"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "upgradeMs",
        "doctorFixMs",
        "gatewayReadyMs",
        "statusMs",
        "pluginsListMs",
        "modelsListMs",
        "missingDependencyErrors",
        "pluginLoadFailures"
      ]
    }
  ]
}
