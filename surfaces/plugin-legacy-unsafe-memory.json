{
  "id": "plugin-legacy-unsafe-memory",
  "title": "Plugin Legacy Unsafe Memory",
  "ownerArea": "plugins",
  "description": "Install a legacy plugin fixture that relies on unsafe buffer behavior and verify OpenClaw fails it closed while keeping the gateway usable.",
  "processRoles": [
    "gateway",
    "command-tree",
    "plugin-cli",
    "runtime-staging"
  ],
  "thresholds": {
    "gatewayReadyMs": 30000,
    "statusMs": 10000,
    "pluginLoadFailures": 2,
    "missingDependencyErrors": 0
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 850,
      "maxCpuPercent": 250
    },
    "plugin-cli": {
      "peakRssMb": 650,
      "maxCpuPercent": 250
    },
    "runtime-staging": {
      "peakRssMb": 900,
      "maxCpuPercent": 350
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "plugins.install",
      "plugins.load"
    ]
  },
  "purposes": [
    "diagnostic",
    "plugin",
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "fail-closed",
      "states": [
        "fresh"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "pluginLoadFailures",
        "missingDependencyErrors",
        "statusMs",
        "gatewayReadyMs"
      ]
    }
  ]
}
