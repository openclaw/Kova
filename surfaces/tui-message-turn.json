{
  "id": "tui-message-turn",
  "title": "TUI Visible Message Smoke",
  "ownerArea": "tui",
  "description": "Launch the OpenClaw TUI, send a real stdin message, and require the expected marker to render in terminal output. This is UI smoke coverage, not structured agent-turn correctness proof.",
  "processRoles": [
    "gateway",
    "command-tree",
    "tui-cli",
    "agent-process",
    "mock-provider"
  ],
  "resourcePrimaryRole": "tui-cli",
  "thresholds": {
    "peakRssMb": 900,
    "postReadyHealthP95Ms": 1000
  },
  "roleThresholds": {
    "gateway": {
      "peakRssMb": 700,
      "maxCpuPercent": 250
    },
    "tui-cli": {
      "peakRssMb": 900,
      "maxCpuPercent": 300
    },
    "mock-provider": {
      "peakRssMb": 250,
      "maxCpuPercent": 150
    }
  },
  "diagnostics": {
    "timelineRequiredForSourceBuild": true,
    "expectedSpans": [
      "gateway.ready"
    ]
  },
  "purposes": [
    "regression",
    "release"
  ],
  "requirements": [
    {
      "id": "baseline",
      "states": [
        "mock-openai-provider"
      ],
      "targetKinds": [
        "npm",
        "release",
        "runtime",
        "local-build"
      ],
      "metrics": [
        "postReadyHealthP95Ms",
        "peakRssMb",
        "pluginLoadFailures"
      ]
    }
  ]
}
