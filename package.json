{
  "name": "@shakkernerd/kova",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw runtime validation lab",
  "type": "module",
  "bin": {
    "kova": "./bin/kova.mjs"
  },
  "scripts": {
    "kova": "node bin/kova.mjs",
    "plan": "node bin/kova.mjs plan",
    "check": "npm run test:selfcheck-isolation && node bin/kova.mjs self-check",
    "check:web-payload": "node scripts/check-web-payload.mjs",
    "test:selfcheck-isolation": "node tests/selfcheck-isolation.mjs",
    "test:snapshots": "node tests/render-snapshots.mjs",
    "pack:release": "scripts/package-release.sh",
    "check:changed": "npm run check",
    "test:changed": "npm run check",
    "crabbox:hydrate": "crabbox actions hydrate",
    "crabbox:run": "crabbox run",
    "crabbox:stop": "crabbox stop",
    "crabbox:warmup": "crabbox warmup"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "json5": "2.2.3",
    "mock-ai-provider": "0.1.2",
    "zod": "^4.4.3"
  }
}
