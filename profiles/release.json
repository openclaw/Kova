      "platforms": {
        "blocking": [
          "darwin-arm64"
        ],
        "warning": [
          "linux-x64",
          "linux-arm64",
          "wsl2"
        ]
      },
      "requirements": {
        "blocking": [
          "channel-capability-preflight:preflight",
          "channel-capability-shared-runtime-smoke:shared-runtime-smoke",
          "release-runtime-startup:baseline",
          "fresh-install:baseline",
