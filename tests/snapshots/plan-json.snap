        "gateway",
        "command-tree",
        "tui-cli"
      ],
      "thresholds": {
        "tuiSmokeMs": 15000,
        "gatewayReadyMs": 30000,
        "inputLagMs": 1000
      },
      "roleThresholds": {
        "gateway": {
          "peakRssMb": 800,
          "maxCpuPercent": 250
        },
        "tui-cli": {
          "peakRssMb": 500,
          "maxCpuPercent": 200
        }
      },
      "diagnostics": {
        "timelineRequiredForSourceBuild": false,
        "expectedSpans": [
          "tui.attach",
          "tui.input",
          "gateway.websocket"
        ]
      },
      "purposes": [
        "regression",
        "release"
      ],
      "requirements": [
        {
          "id": "baseline",
          "states": [
            "fresh"
          ],
          "targetKinds": [
            "npm",
            "release",
            "runtime",
            "local-build"
          ],
          "metrics": [
            "tuiSmokeMs",
            "gatewayReadyMs",
            "statusMs",
            "inputLagMs",
            "pluginLoadFailures"
          ]
        }
      ]
    },
    {
      "id": "upgrade-existing-user",
      "title": "Existing User Upgrade",
      "ownerArea": "upgrade",
      "description": "Clone existing OpenClaw state, run the real upgrade path, and verify migrations, plugin indexes, runtime deps, gateway readiness, and diagnostics.",
      "processRoles": [
        "gateway",
        "command-tree",
        "runtime-management",
        "package-manager",
        "doctor-cli",
        "plugin-cli"
      ],
      "thresholds": {
        "upgradeMs": 120000,
        "gatewayReadyMs": 45000,
        "statusMs": 10000
      },
      "roleThresholds": {
        "gateway": {
          "peakRssMb": 850,
          "maxCpuPercent": 250
        },
        "runtime-management": {
          "peakRssMb": 900,
          "maxCpuPercent": 350
        },
        "package-manager": {
          "peakRssMb": 900,
          "maxCpuPercent": 350
        },
        "doctor-cli": {
          "peakRssMb": 700,
          "maxCpuPercent": 300
        },
        "plugin-cli": {
          "peakRssMb": 600,
          "maxCpuPercent": 250
        }
      },
      "diagnostics": {
        "timelineRequiredForSourceBuild": true,
        "expectedSpans": [
          "upgrade.apply",
          "doctor.fix",
          "plugins.index.migrate",
          "plugins.runtimeDeps"
        ]
      },
      "purposes": [
        "regression",
        "release",
        "upgrade"
      ],
      "requirements": [
        {
          "id": "baseline",
          "states": [
            "failed-upgrade",
            "old-release-2026-4-20-user",
            "old-release-2026-4-24-user",
            "old-release-user",
            "onboarded-user",
            "plugin-index",
            "stable-release-user"
          ],
          "targetKinds": [
            "npm",
            "release",
            "runtime",
            "local-build"
          ],
          "metrics": [
            "upgradeMs",
            "gatewayReadyMs",
            "statusMs",
            "pluginIndexPresent",
            "doctorFixMs"
          ]
        }
      ]
    },
    {
      "id": "workspace-scan",
      "title": "Workspace Scan Pressure",
      "ownerArea": "workspace-runtime",
      "description": "Exercise OpenClaw with a large workspace tree to catch synchronous filesystem scans, slow command paths, memory growth, and event-loop stalls.",
      "processRoles": [
        "gateway",
        "gateway-tree",
        "command-tree",
        "status-cli",
        "plugin-cli",
        "model-cli"
      ],
      "thresholds": {
        "warmReadyMs": 30000,
        "statusMs": 10000,
        "pluginsListMs": 15000,
        "modelsListMs": 20000,
        "soakCommandP95Ms": 12000,
        "soakHealthP95Ms": 1000,
        "peakRssMb": 1000,
        "eventLoopMaxMs": 500,
        "postReadyHealthP95Ms": 1000
      },
      "roleThresholds": {
        "gateway": {
          "peakRssMb": 900,
          "maxCpuPercent": 300
        },
        "gateway-tree": {
          "peakRssMb": 1100,
          "maxCpuPercent": 350
        },
        "model-cli": {
          "peakRssMb": 800,
          "maxCpuPercent": 300
        },
        "plugin-cli": {
          "peakRssMb": 700,
          "maxCpuPercent": 250
        }
      },
      "diagnostics": {
        "timelineRequiredForSourceBuild": true,
        "expectedSpans": [
          "workspace.scan",
          "config.normalize",
          "models.catalog",
          "plugins.metadata.scan",
          "eventLoop.delay"
        ]
      },
      "purposes": [
        "performance",
        "regression"
      ],
      "requirements": [
        {
          "id": "baseline",
          "states": [
            "large-workspace"
          ],
          "targetKinds": [
            "npm",
            "release",
            "runtime",
            "local-build"
          ],
          "metrics": [
            "warmReadyMs",
            "statusMs",
            "pluginsListMs",
            "modelsListMs",
            "soakCommandP95Ms",
            "soakHealthP95Ms",
            "peakRssMb",
            "postReadyHealthP95Ms",
            "eventLoopMaxMs"
          ]
        }
      ]
    }
