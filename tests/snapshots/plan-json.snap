  "processRoles": [
    {
      "id": "agent-cli",
      "title": "Agent CLI",
      "description": "User-facing OpenClaw agent command invocations that send messages or manage local sessions.",
      "commandPatterns": [
        "agent --local",
        "agent --session-id",
        " -- agent ",
        "run-concurrent-agent-turns.mjs"
      ],
      "processPatterns": [
        "(^|\\s|/)openclaw\\s+.*\\bagent\\b",
        "(^|\\s|/)openclaw-agent(\\s|$)"
      ]
    },
    {
      "id": "agent-process",
      "title": "Agent Process",
      "description": "Longer-running agent execution work spawned by OpenClaw while processing a turn.",
      "commandPatterns": [
        "(^|\\s)agent(\\s|$)"
      ],
      "processPatterns": [
        "(^|\\s|/)openclaw-agent(\\s|$)",
        "(^|\\s|/)openclaw\\s+.*\\bsession\\b",
        "(^|\\s|/)openclaw\\s+.*\\bagent\\b"
      ]
    },
    {
      "id": "browser-sidecar",
      "title": "Browser Sidecar",
      "description": "Browser automation sidecar processes and browser control services started by OpenClaw.",
      "commandPatterns": [
        "(^|\\s)browser(\\s|$)",
        "browser-automation-smoke\\.mjs",
        "playwright"
      ],
      "processPatterns": [
        "openclaw-browser",
        "chrome-devtools-mcp",
        "Google Chrome",
        "Chrome Helper",
        "playwright",
        "browser/server",
        "chromium"
      ]
    },
    {
      "id": "build-tooling",
      "title": "Build Tooling",
      "description": "OpenClaw build and postbuild tooling used by release-shaped local builds.",
      "commandPatterns": [
        "build",
        "build-local",
        "postbuild",
        "runtime-postbuild"
      ],
      "processPatterns": [
        "tsc",
        "vite",
        "rollup",
        "esbuild",
        "runtime-postbuild"
      ]
    },
    {
      "id": "cleanup",
      "title": "Cleanup",
      "description": "Environment, service, runtime, and artifact cleanup commands used after Kova runs.",
      "commandPatterns": [
        "ocm env destroy",
        "ocm runtime remove",
        "ocm cleanup"
      ],
      "processPatterns": []
    },
    {
      "id": "command-tree",
      "title": "Command Tree",
      "description": "The complete process tree for an OpenClaw CLI command invoked by Kova.",
      "commandPatterns": [
        "ocm @",
        "ocm start",
        "ocm upgrade"
      ],
      "processPatterns": [
        "openclaw",
        "node.*openclaw"
      ]
    },
    {
      "id": "cron-runtime",
      "title": "Cron Runtime",
      "description": "OpenClaw cron scheduler, cron CLI, run-now, and cron-triggered agent/session execution paths.",
      "commandPatterns": [
        "(^|\\s)cron(\\s|$)",
        "run-cron-runtime-smoke\\.mjs"
      ],
      "processPatterns": [
        "openclaw.*cron",
        "run-cron-runtime-smoke\\.mjs"
      ]
    },
    {
      "id": "dashboard-cli",
      "title": "Dashboard CLI",
      "description": "OpenClaw dashboard command paths that produce or validate dashboard URLs and websocket configuration.",
      "commandPatterns": [
        "dashboard",
        "dashboard --no-open"
      ],
      "processPatterns": [
        "openclaw.*dashboard"
      ]
    },
    {
      "id": "doctor-cli",
      "title": "Doctor CLI",
      "description": "OpenClaw doctor and repair commands used during upgrade and state recovery checks.",
      "commandPatterns": [
        "doctor",
        "doctor --fix"
      ],
      "processPatterns": [
        "openclaw.*doctor"
      ]
    },
    {
      "id": "gateway-session-client",
      "title": "Gateway Session Client",
      "description": "Kova helper process that drives the shared Gateway sessions.create, sessions.send, and chat.history path directly over Gateway RPC.",
      "commandPatterns": [
        "run-gateway-session-send-turn.mjs",
        "sessions.create",
        "sessions.send",
        "chat.history"
      ],
      "processPatterns": [
        "node\\s+.*run-gateway-session-send-turn\\.mjs"
      ]
    },
    {
      "id": "gateway-tree",
      "title": "Gateway Process Tree",
      "description": "The OpenClaw gateway process and its direct children during startup, runtime, and shutdown.",
      "commandPatterns": [
        "gateway run",
        "ocm start",
        "ocm service restart"
      ],
      "processPatterns": [
        "openclaw-gateway",
        "node.*gateway"
      ]
    },
    {
      "id": "gateway",
      "title": "Gateway",
      "description": "The primary OpenClaw gateway service that exposes status, dashboard, websocket, plugin, and agent coordination surfaces.",
      "commandPatterns": [
        "gateway run",
        "ocm start",
        "ocm service status"
      ],
      "processPatterns": [
        "openclaw-gateway",
        "node.*gateway"
      ]
    },
    {
      "id": "mcp-runtime",
      "title": "MCP Runtime",
      "description": "MCP server and transport subprocesses started by OpenClaw or plugins.",
      "commandPatterns": [
        "(^|\\s)mcp\\s+serve(\\s|$)",
        "mcp-bridge-smoke\\.mjs"
      ],
      "processPatterns": [
        "(^|\\s)mcp\\s+serve(\\s|$)",
        "mcp-bridge-smoke\\.mjs"
      ]
    },
    {
      "id": "mock-provider",
      "title": "Mock Provider",
      "description": "Kova-controlled provider fixtures used to test OpenClaw model and agent paths without external provider instability.",
      "commandPatterns": [
        "mock-ai-provider"
      ],
      "processPatterns": [
        "mock-ai-provider"
      ]
    },
    {
      "id": "model-cli",
      "title": "Model CLI",
      "description": "OpenClaw model/provider discovery command paths.",
      "commandPatterns": [
        "models\\s+list",
        "(^|\\s)configure(\\s|$)"
      ],
      "processPatterns": [
        "openclaw.*models"
      ]
    },
    {
      "id": "openai-compatible-client",
      "title": "OpenAI-Compatible Client",
      "description": "Kova client process that drives OpenClaw's OpenAI-compatible HTTP API.",
      "commandPatterns": [
        "run-openai-compatible-turn.mjs",
        "run-adversarial-inputs.mjs",
        "/v1/chat/completions"
      ],
      "processPatterns": [
        "node\\s+.*run-openai-compatible-turn\\.mjs",
        "node\\s+.*run-adversarial-inputs\\.mjs"
      ]
    },
    {
      "id": "package-manager",
      "title": "Package Manager",
      "description": "npm, pnpm, and install/update subprocesses that affect release-shaped OpenClaw runtimes and plugin dependencies.",
      "commandPatterns": [
        "npm",
        "pnpm",
        "npm install",
        "pnpm install",
        "pnpm build"
      ],
      "processPatterns": [
        "npm",
        "pnpm",
        "node.*postinstall"
      ]
    },
    {
      "id": "plugin-cli",
      "title": "Plugin CLI",
      "description": "OpenClaw plugin commands including install, uninstall, list, update, and registry refresh.",
      "commandPatterns": [
        "plugins list",
        "plugins install",
        "plugins uninstall",
        "plugins update",
        "plugins registry"
      ],
      "processPatterns": [
        "openclaw.*plugins"
      ]
    },
    {
      "id": "runtime-management",
      "title": "Runtime Management",
      "description": "Runtime install, upgrade, local-build, and binding operations used before OpenClaw starts.",
      "commandPatterns": [
        "ocm\\s+runtime",
        "ocm\\s+upgrade",
        "ocm\\s+start\\b.*--runtime"
      ],
      "processPatterns": [
        "ocm\\s+runtime",
        "ocm\\s+start\\b.*--runtime",
        "npm.*openclaw"
      ]
    },
    {
      "id": "runtime-staging",
      "title": "Runtime Dependency Staging",
      "description": "OpenClaw bundled plugin runtime dependency staging and package overlay work.",
      "commandPatterns": [
        "runtime deps",
        "bundled runtime deps"
      ],
      "processPatterns": [
        "node.*bundled",
        "npm.*node_modules"
      ]
    },
    {
      "id": "status-cli",
      "title": "Status CLI",
      "description": "OpenClaw status and health inspection commands used to prove the gateway is usable.",
      "commandPatterns": [
        "status",
        "service status"
      ],
      "processPatterns": [
        "openclaw.*status"
      ]
    },
    {
      "id": "tool-runtime",
      "title": "Tool Runtime",
      "description": "OpenClaw agent tool execution, exec policy, MCP tool calls, and tool-failure containment helpers.",
      "commandPatterns": [
        "exec-policy",
        "exec-approvals",
        "run-exec-tool-safety\\.mjs",
        "mcp-tool-call-smoke\\.mjs"
      ],
      "processPatterns": [
        "openclaw.*exec",
        "run-exec-tool-safety\\.mjs",
        "mcp-tool-call-smoke\\.mjs"
      ]
    },
    {
      "id": "tui-cli",
      "title": "TUI CLI",
      "description": "OpenClaw terminal UI attachment, rendering, input, and shutdown paths.",
      "commandPatterns": [
        "tui",
        "support/tui-smoke.mjs",
        "run-tui-message-turn.mjs"
      ],
      "processPatterns": [
        "openclaw.*tui",
        "node\\s+.*run-tui-message-turn\\.mjs"
      ]
    }
  ],
