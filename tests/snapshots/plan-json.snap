          "userAction": "user asks OpenClaw to make an image for this chat and receives the completed image in the same chat",
          "openclawSurface": "channel inbound direct message with background generated image delivery",
          "prompt": "Create a simple launch announcement image for this chat.",
          "providerScript": {
            "toolCalls": [
              {
                "name": "image_generate",
                "arguments": {
                  "action": "generate",
                  "prompt": "simple launch announcement image",
                  "filename": "kova-completion-handoff-direct.png",
                  "count": 1
                }
              }
            ],
            "finalText": "NO_REPLY",
            "completionToolCalls": [
              {
                "name": "message",
                "arguments": {
                  "action": "send",
                  "message": "The generated image is ready.",
                  "media": "{{kova.generatedMediaPath}}"
                }
              }
            ],
            "completionFinalText": "NO_REPLY"
          },
          "expects": {
            "visibleDeliveries": 1,
            "kind": "media",
            "replyTo": "none",
