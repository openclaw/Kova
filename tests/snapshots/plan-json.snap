  "channelCapabilityCatalog": [
    {
      "schemaVersion": "kova.channelCapabilityCatalog.v1",
      "id": "openclaw-message",
      "title": "OpenClaw Message Channel Capabilities",
      "declarationSources": [
        "src/channels/message/types.ts",
        "src/channels/message/contracts.ts",
        "src/channels/message/contracts.test.ts",
        "src/channels/message/runtime-workflows",
        "src/infra/outbound/source-delivery-plan.ts",
        "src/agents/pi-embedded-runner/run/payloads.ts",
        "src/channels/turn/bot-loop-protection.ts",
        "src/agents/subagent-announce-delivery.ts"
      ],
      "capabilities": [
        {
          "id": "text",
          "group": "durable-final",
          "title": "Durable Final Text",
          "sourceSymbol": "durableFinalDeliveryCapabilities.text",
          "baselineExpectation": "final assistant text can be rendered, sent, receipted, and committed through the shared message-channel path",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim",
            "live-smoke"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "media",
          "group": "durable-final",
          "title": "Durable Final Media",
          "sourceSymbol": "durableFinalDeliveryCapabilities.media",
          "baselineExpectation": "generated media can be rendered, sent, receipted, and committed through the shared message-channel path",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim",
            "live-smoke"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "payload",
          "group": "durable-final",
          "title": "Durable Final Payload",
          "sourceSymbol": "durableFinalDeliveryCapabilities.payload",
          "baselineExpectation": "reply payloads can be rendered into channel sends without losing text, media, or presentation data",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "silent",
          "group": "durable-final",
          "title": "Durable Final Silent Delivery",
          "sourceSymbol": "durableFinalDeliveryCapabilities.silent",
          "baselineExpectation": "silent delivery intent is carried through durable final send requirements and adapter context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "reply-to",
          "group": "durable-final",
          "title": "Durable Final Reply Target",
          "sourceSymbol": "durableFinalDeliveryCapabilities.replyTo",
          "baselineExpectation": "reply target intent is carried through durable final send requirements and adapter context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "thread",
          "group": "durable-final",
          "title": "Durable Final Thread Target",
          "sourceSymbol": "durableFinalDeliveryCapabilities.thread",
          "baselineExpectation": "thread target intent is carried through durable final send requirements and adapter context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "native-quote",
          "group": "durable-final",
