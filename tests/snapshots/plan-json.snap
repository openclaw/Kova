  "channelCapabilityCatalog": [
    {
      "schemaVersion": "kova.channelCapabilityCatalog.v1",
      "id": "openclaw-message",
      "title": "OpenClaw Message Channel Capabilities",
      "declarationSources": [
        "src/channels/message/types.ts",
        "src/channels/message/contracts.ts",
        "src/channels/message/contracts.test.ts",
        "src/channels/message/runtime-workflows",
        "src/channels/plugins/message-action-discovery.ts",
        "src/channels/plugins/message-capabilities.ts",
        "src/channels/plugins/outbound.types.ts",
        "src/infra/outbound/source-delivery-plan.ts",
        "src/agents/pi-embedded-runner/run/payloads.ts",
        "src/channels/turn/bot-loop-protection.ts",
        "src/channels/inbound-event/context.ts",
        "src/channels/inbound-event/media.ts",
        "src/agents/subagent-announce-delivery.ts"
      ],
      "capabilities": [
        {
          "id": "text",
          "group": "durable-final",
          "title": "Durable Final Text",
          "sourceSymbol": "durableFinalDeliveryCapabilities.text",
          "baselineExpectation": "final assistant text can be rendered, sent, receipted, and committed through the shared message-channel path",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim",
            "live-smoke"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "media",
          "group": "durable-final",
          "title": "Durable Final Media",
          "sourceSymbol": "durableFinalDeliveryCapabilities.media",
          "baselineExpectation": "generated media can be rendered, sent, receipted, and committed through the shared message-channel path",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim",
            "live-smoke"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "poll",
          "group": "durable-final",
          "title": "Durable Final Poll",
          "sourceSymbol": "durableFinalDeliveryCapabilities.poll",
          "baselineExpectation": "poll results can be rendered, sent, receipted, and committed through the shared message-channel path",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim",
            "live-smoke"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "payload",
          "group": "durable-final",
          "title": "Durable Final Payload",
          "sourceSymbol": "durableFinalDeliveryCapabilities.payload",
          "baselineExpectation": "reply payloads can be rendered into channel sends without losing text, media, or presentation data",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "silent",
          "group": "durable-final",
          "title": "Durable Final Silent Delivery",
          "sourceSymbol": "durableFinalDeliveryCapabilities.silent",
          "baselineExpectation": "silent delivery intent is carried through durable final send requirements and adapter context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "reply-to",
          "group": "durable-final",
          "title": "Durable Final Reply Target",
          "sourceSymbol": "durableFinalDeliveryCapabilities.replyTo",
          "baselineExpectation": "reply target intent is carried through durable final send requirements and adapter context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "thread",
          "group": "durable-final",
          "title": "Durable Final Thread Target",
          "sourceSymbol": "durableFinalDeliveryCapabilities.thread",
          "baselineExpectation": "thread target intent is carried through durable final send requirements and adapter context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "native-quote",
          "group": "durable-final",
          "title": "Durable Final Native Quote",
          "sourceSymbol": "durableFinalDeliveryCapabilities.nativeQuote",
          "baselineExpectation": "native quote intent can be represented as a declared durable final capability and proven by adapters that support it",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "message-sending-hooks",
          "group": "durable-final",
          "title": "Durable Final Message Sending Hooks",
          "sourceSymbol": "durableFinalDeliveryCapabilities.messageSendingHooks",
          "baselineExpectation": "message sending hooks run around durable final sends without losing attempt context",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "batch",
          "group": "durable-final",
          "title": "Durable Final Batch",
          "sourceSymbol": "durableFinalDeliveryCapabilities.batch",
          "baselineExpectation": "multi-part durable final payloads preserve ordering and receipts",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "reconcile-unknown-send",
          "group": "durable-final",
          "title": "Durable Final Unknown Send Reconciliation",
          "sourceSymbol": "durableFinalDeliveryCapabilities.reconcileUnknownSend",
          "baselineExpectation": "ambiguous durable send outcomes can be reconciled without duplicate or lost final delivery",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "after-send-success",
          "group": "durable-final",
          "title": "Durable Final After Send Success Hook",
          "sourceSymbol": "durableFinalDeliveryCapabilities.afterSendSuccess",
          "baselineExpectation": "after-send-success lifecycle hooks run after successful platform send attempts",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "after-commit",
          "group": "durable-final",
          "title": "Durable Final After Commit Hook",
          "sourceSymbol": "durableFinalDeliveryCapabilities.afterCommit",
          "baselineExpectation": "after-commit lifecycle hooks run after durable final receipts are committed",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "draft-preview",
          "group": "live-preview",
          "title": "Live Draft Preview",
          "sourceSymbol": "channelMessageLiveCapabilities.draftPreview",
          "baselineExpectation": "draft preview state can be declared and proven through the shared live message adapter contract",
          "proofModes": [
            "preflight",
            "baseline",
            "deterministic-shim",
            "live-smoke"
          ],
          "declarationSource": "src/channels/message/types.ts"
        },
        {
          "id": "preview-finalization",
          "group": "live-preview",
          "title": "Live Preview Finalization",
