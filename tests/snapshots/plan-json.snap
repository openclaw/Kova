      "commandPatterns": [
        "ocm env destroy",
        "ocm runtime remove",
        "ocm cleanup"
      ],
      "processPatterns": []
    },
    {
      "id": "command-tree",
      "title": "Command Tree",
      "description": "The complete process tree for an OpenClaw CLI command invoked by Kova.",
      "commandPatterns": [
        "ocm @",
        "ocm start",
        "ocm upgrade"
      ],
      "processPatterns": [
        "openclaw",
        "node.*openclaw"
      ]
    },
    {
      "id": "dashboard-cli",
      "title": "Dashboard CLI",
