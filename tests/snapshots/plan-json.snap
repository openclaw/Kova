          "eventLoop.delay"
        ]
      },
      "purposes": [
        "performance",
        "regression"
      ],
      "requirements": [
        {
          "id": "baseline",
          "states": [
            "large-workspace"
          ],
          "targetKinds": [
            "npm",
            "channel",
            "runtime",
            "local-build"
          ],
          "metrics": [
            "warmReadyMs",
            "statusMs",
            "pluginsListMs",
            "modelsListMs",
            "soakCommandP95Ms",
            "soakHealthP95Ms",
            "peakRssMb",
            "postReadyHealthP95Ms",
            "eventLoopMaxMs"
          ]
        }
      ]
