---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { latestRelease, scenarioCounts } from "../../lib/releases";
import { fmtVal } from "../../lib/format";
import {
  fmtMs,
  fmtBytes,
  fmtRunStamp,
  fmtMetric,
  deltaClass,
} from "../../lib/release-format";
import RunScenarioCard from "../../components/RunScenarioCard.astro";
import ScenarioTile from "../../components/ScenarioTile.astro";
import type {
  Headline,
  Run,
  ComparisonRow,
  Scenario,
} from "../../content.config";

export async function getStaticPaths() {
  const all = await getCollection("releases");
  return all.map((entry) => ({
    params: { version: entry.data.ver },
    props: { release: entry.data },
  }));
}

const { release } = Astro.props;
const latest = await latestRelease();
const hasDetail = Boolean(release.scenarios && release.scenarios.length);
const counts = hasDetail ? scenarioCounts(release.scenarios!) : null;
const runsList: Run[] = release.runs ?? [];
const hasRuns = runsList.length > 0;
const publicHeadlines = (release.headline ?? []).filter((h: Headline) => !isResourceMetric(h.metric));
const publicComparisonRows = release.comparison?.rows.filter((row: ComparisonRow) => !isResourceMetric(row.metric)) ?? [];

function isResourceMetric(metric: string | undefined): boolean {
  return /\b(rss|cpu|memory)\b/i.test(metric ?? "");
}
---

<Base
  title={`kova — OpenClaw ${release.ver}`}
  active="releases"
  description={hasDetail && counts
    ? `OpenClaw ${release.ver} · ${counts.pass} pass · ${counts.fail} fail · ${counts.block} blocked · measured by kova.`
    : `OpenClaw ${release.ver} · measured by kova.`}
  ogImage={`/og/${release.ver}.png`}
>
  <div class="container">

    <div class="release-header">
      <a class="release-back" href="/releases" data-history-back>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18 L9 12 L15 6" />
        </svg>
        releases
      </a>
      <h1 class="release-title">{release.ver}</h1>
      <div class="release-tags">
        <span class="release-tag">{release.sha}</span>
        {release.runtimeTargets?.map((t: string) => <span class="release-tag">{t}</span>)}
        <span>{release.date}</span>
      </div>

      {hasDetail && counts && (
        <div class="headline-strip">
          <div class="v2-status-counts">
            <div class="pass"><span class="num">{counts.pass}</span><span class="lbl">pass</span></div>
            <div class="fail"><span class="num">{counts.fail}</span><span class="lbl">fail</span></div>
            <div class="warn"><span class="num">{counts.block}</span><span class="lbl">blocked</span></div>
            <div><span class="num">{counts.total}</span><span class="lbl">total</span></div>
          </div>

          {publicHeadlines.map((h: Headline) => {
            const d = h.deltaPct != null ? deltaClass(h.deltaPct, h.lowerIsBetter !== false) : null;
            return (
              <div class="headline">
                <span class="headline-label">{h.label}</span>
                <span class="headline-metric">
                  {fmtVal(h.value, h.unit)}<span class="headline-unit">{h.unit}</span>
                </span>
                {d && h.deltaPct != null && h.vsVer && (
                  <span class:list={["delta", d.cls]}>
                    {d.arrow} {h.deltaPct > 0 ? "+" : ""}{h.deltaPct.toFixed(1)}% vs {h.vsVer}
                  </span>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>

    {!hasDetail && (
      <p style="font-family:var(--font-mono);font-size:var(--text-2);color:var(--text-3c);max-width:60ch;margin-top:var(--space-5);">
        No detailed scenario data archived for this release.
        Jump to the <a href={`/releases/${latest.ver}`} style="color:var(--text-1c);border-bottom:1px solid var(--border-2);">latest release</a>.
      </p>
    )}

    {hasDetail && (
      <>
        <section>
          <div class="section-rule"><h2>Scenarios</h2></div>
          <div class="v2-wall">
            {release.scenarios!.map((s: Scenario) => (
              <ScenarioTile scenario={s} href={`#scenario-${s.id}`} emptyMessage="— no sample —" />
            ))}
          </div>
        </section>

        {hasRuns && (
          <section>
            <div class="section-rule"><h2>Runs</h2></div>
            <div class="runs-toolbar" data-runs-toolbar>
              <button class="runs-toggle" type="button" data-runs-action="expand">Expand all</button>
              <button class="runs-toggle" type="button" data-runs-action="collapse">Collapse all</button>
            </div>
            <div class="run-list" data-run-list>
              {runsList.map((r: Run) => (
                <details class="run" open={r.expandedByDefault ?? false}>
                  <summary>
                    <span class="caret">▶</span>
                    <span class="col-runtime">{r.runtime}</span>
                    <span class="col-profile">{r.profile}</span>
                    <span class="col-date">{fmtRunStamp(r.startedAt)}</span>
                    <span class="col-dur">{fmtMs(r.durationMs)}</span>
                    <span class="col-samples">{r.entryCount} entries</span>
                    <span class:list={["verdict", r.state === "pass" ? "verdict-pass" : r.state === "fail" ? "verdict-fail" : "verdict-warn"]}>
                      <span class="verdict-dot"></span>{r.state.toUpperCase()}
                    </span>
                  </summary>

                  {r.scenarios && r.scenarios.length > 0 && (
                    <div class="run-body">
                      {r.scenarios.map((rs) => <RunScenarioCard scenario={rs} />)}

                      {r.bundle && (
                        <div style="margin-top: var(--space-5); display: flex; justify-content: flex-end;">
                          <a class="bundle" href={r.bundle.href} style="max-width: 320px;">
                            <span>{r.bundle.name}</span>
                            <span class="bytes">{fmtBytes(r.bundle.bytes)}</span>
                          </a>
                        </div>
                      )}
                    </div>
                  )}
                </details>
              ))}
            </div>
          </section>
        )}

        {release.comparison && publicComparisonRows.length > 0 && (
          <section>
            <div class="section-rule">
              <h2>vs {release.comparison.vsVer}</h2>
            </div>
            <p style="margin: calc(-1 * var(--space-3)) 0 var(--space-3); font-family:var(--font-mono); font-size:var(--text-1); color:var(--text-3c);">
              <a href={`/releases/${release.ver}/vs/${release.comparison.vsVer}`} style="color:var(--text-2c); border-bottom:1px solid var(--border-2);">open full comparison →</a>
            </p>
            <div class="compare">
              {publicComparisonRows.map((row: ComparisonRow) => {
                const d = deltaClass(row.deltaPct, row.lowerIsBetter !== false);
                return (
                  <div class="compare-row">
                    <span class="compare-scenario">{row.scenarioId}</span>
                    <span class="compare-metric">{row.metric}</span>
                    <span class="compare-metric">{fmtMetric(row.before, row.unit)} → {fmtMetric(row.after, row.unit)}</span>
                    <span class:list={["compare-delta", d.cls]}>
                      {d.arrow} {row.deltaPct > 0 ? "+" : ""}{row.deltaPct.toFixed(1)}%
                    </span>
                  </div>
                );
              })}
            </div>
          </section>
        )}

        {runsList.some((r: Run) => r.bundle) && (
          <section>
            <div class="section-rule"><h2>Bundles</h2></div>
            <div class="bundles">
              {runsList.filter((r: Run) => r.bundle).map((r: Run) => (
                <a class="bundle" href={r.bundle!.href}>
                  <span>{r.bundle!.name}</span>
                  <span class="bytes">{fmtBytes(r.bundle!.bytes)}</span>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    )}

  </div>

  <script>
    // Expand/collapse all <details class="run"> within the run list.
    const list = document.querySelector<HTMLElement>("[data-run-list]");
    const toolbar = document.querySelector<HTMLElement>("[data-runs-toolbar]");
    if (list && toolbar) {
      toolbar.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest("[data-runs-action]");
        if (!(btn instanceof HTMLElement)) return;
        const open = btn.dataset.runsAction === "expand";
        list.querySelectorAll<HTMLDetailsElement>("details.run").forEach((d) => {
          d.open = open;
        });
      });
    }
  </script>
</Base>
