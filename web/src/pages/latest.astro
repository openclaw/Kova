---
/**
 * /latest — meta-refresh + canonical to the newest STABLE release.
 * SSG-friendly. Pre-release builds are intentionally never the latest
 * target; if you want a specific beta, navigate to its release page.
 */

import { latestStableRelease } from "../lib/releases";

const latest = await latestStableRelease();
const target = `/releases/${latest.ver}`;
const canonicalUrl = new URL(target, Astro.site).toString();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Kova — latest OpenClaw release</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="description" content={`Latest stable OpenClaw release — redirecting to ${latest.ver}.`} />
    <style>
      body { font-family: ui-monospace, monospace; background: #0a0a0b; color: #fafafa;
        margin: 0; min-height: 100vh; display: grid; place-items: center; padding: 24px; }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <p>Redirecting to <a href={target}>OpenClaw {latest.ver}</a>…</p>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </body>
</html>
