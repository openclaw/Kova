---
/**
 * ScenarioTile — the dense, failure-context-rich scenario tile used by
 * both the home page wall and the release page scenarios grid.
 *
 * The home page passes `href={`/releases/${release.ver}`}` so clicking
 * a tile opens the release. The release page passes
 * `href={`#scenario-${s.id}`}` so clicking a tile jumps to the matching
 * RunScenarioCard further down the same page.
 *
 * Visual is identical in both places by design: threshold, current
 * value, Δ-vs-previous, breach/headroom, sparkline, colored
 * state-aware left border. That makes "why did this fail" answerable
 * at-a-glance on either surface.
 */
import type { Scenario } from "../content.config";
import { fmtVal, deltaFromSpark, deltaText } from "../lib/format";
import { spark } from "../lib/sparkline";

interface Props {
  scenario: Scenario;
  href: string;
  /** Shown in the sparkline slot when there's no `spark` data. */
  emptyMessage?: string;
}

const { scenario: s, href, emptyMessage = "— env failed to provision —" } = Astro.props;

const dInfo = s.spark ? deltaFromSpark(s.spark, s.lowerIsBetter !== false) : null;
const dt = deltaText(dInfo);
const hasValue = s.value != null;
const numericValue = hasValue ? s.value! : null;
const friendlyLabel = s.metric ?? s.id;
const deltaLabel = s.spark ? (s.spark.length < 2 ? "first sample" : dt.text) : (hasValue ? "no sample" : "status");
const valueLabel = hasValue ? fmtVal(s.value, s.unit) : stateText(s.state);
const footLeft = hasValue && s.threshold > 0
  ? `${s.metric ?? "threshold"} ≤ ${fmtVal(s.threshold, s.unit)} ${s.unit}`.trim()
  : (s.metric ?? "status");

let vs = "";
let vsCls = "";
if (s.state === "fail" && numericValue != null) {
  const over = s.threshold > 0 ? ((numericValue - s.threshold) / s.threshold) * 100 : null;
  if (s.worstMetric) {
    vs = formatWorstMetric(s.worstMetric);
  } else if (over != null && over > 0) {
    vs = `+${over.toFixed(1)}% over`;
  } else {
    vs = "failed";
  }
  vsCls = "breach";
} else if (s.state === "fail") {
  vs = s.worstMetric ? formatWorstMetric(s.worstMetric) : "failed";
  vsCls = "breach";
} else if (s.state === "pass" && numericValue != null) {
  const under = s.threshold > 0 ? ((s.threshold - numericValue) / s.threshold) * 100 : null;
  vs = under != null ? `${under.toFixed(0)}% headroom` : "";
} else if (s.state === "pass") {
  vs = "passed";
}

function stateText(state: Scenario["state"]) {
  if (state === "pass") return "passed";
  if (state === "fail") return "failed";
  return "blocked";
}

function formatWorstMetric(metric: NonNullable<Scenario["worstMetric"]>) {
  if (metric.value === 0 && metric.unit === "") return metric.name;
  return `${metric.name} ${fmtVal(metric.value, metric.unit)}${metric.unit}`;
}
---

<a class:list={["v2-tile", s.state]} href={href}>
  <div class="v2-tile-head">
    <span class="v2-tile-name">{friendlyLabel}</span>
    <span class="v2-tile-dot" aria-hidden="true"></span>
  </div>
  <div class="v2-tile-metric">{s.id}</div>
  <div class="v2-tile-row">
    <span class:list={["v2-tile-value", !hasValue && "status-value"]}>
      {valueLabel}{hasValue && s.unit && <span class="unit">{s.unit}</span>}
    </span>
    <span class:list={["v2-tile-delta", dt.cls]}>
      {deltaLabel}
    </span>
  </div>
  {s.spark ? (
    <Fragment set:html={spark(s.spark, { state: s.state })} />
  ) : (
    <div class="v2-tile-empty">{emptyMessage}</div>
  )}
  <div class="v2-tile-foot">
    <span>{footLeft}</span>
    <span class={vsCls}>{vs}</span>
  </div>
</a>
