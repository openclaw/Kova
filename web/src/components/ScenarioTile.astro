---
/**
 * ScenarioTile — the dense, failure-context-rich scenario tile used by
 * both the home page wall and the release page scenarios grid.
 *
 * The home page passes `href={`/releases/${release.ver}`}` so clicking
 * a tile opens the release. The release page passes
 * `href={`#scenario-${s.id}`}` so clicking a tile jumps to the matching
 * RunScenarioCard further down the same page.
 *
 * Visual is identical in both places by design: threshold, current
 * value, Δ-vs-previous, breach/headroom, sparkline, colored
 * state-aware left border. That makes "why did this fail" answerable
 * at-a-glance on either surface.
 */
import type { Scenario } from "../content.config";
import { fmtVal, deltaFromSpark, deltaText } from "../lib/format";
import { spark } from "../lib/sparkline";

interface Props {
  scenario: Scenario;
  href: string;
  /** Shown in the sparkline slot when there's no `spark` data. */
  emptyMessage?: string;
}

const { scenario: s, href, emptyMessage = "— env failed to provision —" } = Astro.props;

const dInfo = s.spark ? deltaFromSpark(s.spark, s.lowerIsBetter !== false) : null;
const dt = deltaText(dInfo);
const deltaLabel = s.spark ? (s.spark.length < 2 ? "first sample" : dt.text) : "no sample";

let vs = "";
let vsCls = "";
if (s.state === "fail" && s.value != null) {
  const over = s.threshold > 0 ? ((s.value - s.threshold) / s.threshold) * 100 : null;
  if (over != null && over > 0) {
    vs = `+${over.toFixed(1)}% over`;
  } else if (s.worstMetric) {
    vs = s.worstMetric.name;
  } else {
    vs = "failed";
  }
  vsCls = "breach";
} else if (s.state === "pass" && s.value != null) {
  const under = s.threshold > 0 ? ((s.threshold - s.value) / s.threshold) * 100 : null;
  vs = under != null ? `${under.toFixed(0)}% headroom` : "";
}
---

<a class:list={["v2-tile", s.state]} href={href}>
  <div class="v2-tile-head">
    <span class="v2-tile-name">{s.id}</span>
    <span class="v2-tile-dot" aria-hidden="true"></span>
  </div>
  {s.metric && <div class="v2-tile-metric">{s.metric}</div>}
  <div class="v2-tile-row">
    <span class="v2-tile-value">
      {fmtVal(s.value, s.unit)}<span class="unit">{s.unit}</span>
    </span>
    <span class:list={["v2-tile-delta", dt.cls]}>
      {deltaLabel}
    </span>
  </div>
  {s.spark ? (
    <Fragment set:html={spark(s.spark, { state: s.state })} />
  ) : (
    <div class="v2-tile-empty">{emptyMessage}</div>
  )}
  <div class="v2-tile-foot">
    <span>{s.metric ?? "threshold"} ≤ {fmtVal(s.threshold, s.unit)} {s.unit}</span>
    <span class={vsCls}>{vs}</span>
  </div>
</a>
