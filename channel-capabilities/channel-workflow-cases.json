    {
      "id": "source-visible-delivery.text.automatic-final",
      "workflow": "source-visible-delivery",
      "userAction": "user asks OpenClaw a normal question and receives the final answer in the same chat",
      "openclawSurface": "channel inbound direct message with automatic source delivery",
      "ownerArea": "OpenClaw source delivery runtime",
      "prompt": "Summarize the launch checklist in one sentence.",
      "providerScript": {
        "finalText": "KOVA_SOURCE_DELIVERY_TEXT_AUTO_OK"
      },
      "expects": {
        "visibleDeliveries": 1,
        "kind": "text",
        "text": "KOVA_SOURCE_DELIVERY_TEXT_AUTO_OK",
        "terminal": true,
        "noDuplicateFinal": true
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 1
      },
      "atoms": [
        { "group": "workflow", "id": "source-visible-delivery" },
        { "group": "durable-final", "id": "text" }
      ]
    },
    {
      "id": "source-visible-delivery.text.message-tool-only",
      "workflow": "source-visible-delivery",
      "userAction": "user asks OpenClaw for an update that must be delivered through the source chat message path",
      "openclawSurface": "channel inbound direct message with source conversation delivery",
      "ownerArea": "OpenClaw source delivery runtime",
      "prompt": "Post a short product launch update for this chat.",
      "providerScript": {
        "toolCalls": [
          {
            "name": "message",
            "arguments": {
              "action": "send",
              "message": "KOVA_SOURCE_DELIVERY_TEXT_TOOL_OK"
            }
          }
        ],
        "finalText": "KOVA_SOURCE_DELIVERY_PRIVATE_DONE"
      },
      "sourceReplyDeliveryMode": "message_tool_only",
      "expects": {
        "visibleDeliveries": 1,
        "kind": "text",
        "text": "KOVA_SOURCE_DELIVERY_TEXT_TOOL_OK",
        "hooks": true,
        "terminal": true,
        "noDuplicateFinal": true
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 2
      },
      "atoms": [
        { "group": "workflow", "id": "source-visible-delivery" },
        { "group": "workflow", "id": "message-tool-only-source-delivery" },
        { "group": "durable-final", "id": "text" },
        { "group": "durable-final", "id": "message-sending-hooks" }
      ]
    },
    {
      "id": "background-artifact-completion.video.message-tool-only",
      "workflow": "background-artifact-completion",
      "userAction": "user asks OpenClaw to create a video and receives the completed video in the same chat",
      "openclawSurface": "channel inbound direct message with background media-generation completion",
      "ownerArea": "OpenClaw completion delivery runtime",
      "prompt": "Create a short launch teaser video with the app logo at the end.",
      "providerScript": {
        "toolCalls": [
          {
            "name": "message",
            "arguments": {
              "action": "send",
              "message": "KOVA_BACKGROUND_VIDEO_READY",
              "media": "/tmp/kova-background-video.mp4"
            }
          }
        ],
        "finalText": "KOVA_BACKGROUND_COMPLETION_PRIVATE_DONE"
      },
      "sourceReplyDeliveryMode": "message_tool_only",
      "expects": {
        "visibleDeliveries": 1,
        "kind": "media",
        "text": "KOVA_BACKGROUND_VIDEO_READY",
        "mediaSource": "/tmp/kova-background-video.mp4",
        "mediaSourcePolicy": "sendable-local-or-managed",
        "hooks": true,
        "terminal": true,
        "noDuplicateFinal": true
      },
      "fixtures": {
        "mediaPath": "/tmp/kova-background-video.mp4"
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 2
      },
      "atoms": [
        { "group": "workflow", "id": "background-artifact-completion" },
        { "group": "workflow", "id": "source-visible-delivery" },
        { "group": "workflow", "id": "message-tool-only-source-delivery" },
        { "group": "durable-final", "id": "media" },
        { "group": "durable-final", "id": "message-sending-hooks" }
      ]
    },
    {
      "id": "failure-visible-once.provider-error",
      "workflow": "failure-visible-once",
      "userAction": "user sends a normal channel message while the configured model provider is failing and receives one clear error response",
      "openclawSurface": "channel inbound direct message with provider failure",
      "ownerArea": "OpenClaw channel runtime",
      "prompt": "Check the launch status for this chat.",
      "providerScript": {
        "errorStatus": 503
      },
      "expects": {
        "visibleDeliveries": 1,
        "kind": "text",
        "errorFinal": true,
        "terminal": true,
        "noDuplicateFinal": true
      },
      "providerRequests": {
        "mode": "minimum",
        "min": 1
      },
      "atoms": [
        { "group": "workflow", "id": "failure-visible-once" },
        { "group": "workflow", "id": "single-inbound-single-final" },
        { "group": "workflow", "id": "terminal-after-final" },
        { "group": "durable-final", "id": "text" }
      ]
    },
    {
