{
  "schemaVersion": "kova.channelWorkflowCaseCatalog.v1",
  "id": "openclaw-channel-workflow-cases",
  "title": "OpenClaw Channel Workflow Cases",
  "description": "User-shaped OpenClaw channel workflow cases executed through the Kova fixture channel and deterministic provider scripts.",
  "cases": [
    {
      "id": "text-final",
      "workflow": "final-text-reply",
      "userAction": "user sends a normal text message and receives a text answer in the same conversation",
      "openclawSurface": "channel inbound direct message",
      "ownerArea": "OpenClaw channel runtime",
      "prompt": "Give me a short launch status update for the team.",
      "providerScript": {
        "finalText": "KOVA_AGENT_OK"
      },
      "expects": {
        "visibleDeliveries": 1,
        "kind": "text",
        "text": "KOVA_AGENT_OK",
        "replyTo": "inbound-message",
        "hooks": true,
        "terminal": true
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 1
      },
      "atoms": [
        { "group": "durable-final", "id": "text" },
        { "group": "durable-final", "id": "reply-to" },
        { "group": "durable-final", "id": "message-sending-hooks" },
        { "group": "durable-final", "id": "after-send-success" },
        { "group": "durable-final", "id": "after-commit" },
        { "group": "workflow", "id": "single-inbound-single-final" },
        { "group": "workflow", "id": "final-delivery-receipt-required" },
        { "group": "workflow", "id": "terminal-after-final" },
        { "group": "ack", "id": "after-agent-dispatch" },
        { "group": "ack", "id": "after-durable-send" }
      ]
    },
    {
      "id": "media-final",
      "workflow": "final-media-reply",
      "userAction": "user asks OpenClaw for a media result and receives the media in the same conversation",
      "openclawSurface": "channel inbound direct message",
      "ownerArea": "OpenClaw channel runtime",
      "prompt": "Create a simple launch image with a short caption.",
      "providerScript": {
        "finalText": "MEDIA:/tmp/kova-channel-model-turn-media.png\nKOVA_AGENT_MEDIA_OK"
      },
      "expects": {
        "visibleDeliveries": 1,
        "kind": "media",
        "text": "KOVA_AGENT_MEDIA_OK",
        "replyTo": "inbound-message",
        "mediaSource": "/tmp/kova-channel-model-turn-media.png",
        "mediaSourcePolicy": "exact",
        "terminal": true
      },
      "fixtures": {
        "mediaPath": "/tmp/kova-channel-model-turn-media.png"
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 1
      },
      "atoms": [
        { "group": "durable-final", "id": "media" },
        { "group": "workflow", "id": "single-inbound-single-final" },
        { "group": "workflow", "id": "final-delivery-receipt-required" },
        { "group": "workflow", "id": "terminal-after-final" }
      ]
    },
    {
      "id": "media-thread-final",
      "workflow": "final-media-thread",
      "userAction": "user asks for a media result from inside a thread and receives the media in that thread",
      "openclawSurface": "channel inbound threaded message",
      "ownerArea": "OpenClaw channel runtime",
      "prompt": "Create a launch image for this thread.",
      "providerScript": {
        "finalText": "MEDIA:/tmp/kova-channel-model-turn-media-thread.png\nKOVA_AGENT_MEDIA_THREAD_OK"
      },
      "expects": {
        "visibleDeliveries": 1,
        "kind": "media",
        "text": "KOVA_AGENT_MEDIA_THREAD_OK",
        "replyTo": "none",
        "threadId": "kova-model-turn-thread",
        "mediaSource": "/tmp/kova-channel-model-turn-media-thread.png",
        "mediaSourcePolicy": "exact",
        "terminal": true,
        "noDuplicateFinal": true
      },
      "fixtures": {
        "mediaPath": "/tmp/kova-channel-model-turn-media-thread.png"
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 1
      },
      "atoms": [
        { "group": "durable-final", "id": "media" },
        { "group": "durable-final", "id": "thread" },
        { "group": "workflow", "id": "media-thread-final" },
        { "group": "workflow", "id": "single-inbound-single-final" },
        { "group": "workflow", "id": "final-delivery-receipt-required" },
        { "group": "workflow", "id": "terminal-after-final" }
      ]
    },
    {
      "id": "media-reply-thread-final",
      "workflow": "final-media-reply-thread",
      "userAction": "user replies in a thread and receives OpenClaw's media answer against the right message in that thread",
      "openclawSurface": "channel inbound threaded reply message",
      "ownerArea": "OpenClaw channel runtime",
      "prompt": "Create a launch image as a reply in this thread.",
      "providerScript": {
        "finalText": "MEDIA:/tmp/kova-channel-model-turn-media-reply-thread.png\nKOVA_AGENT_MEDIA_REPLY_THREAD_OK"
      },
      "expects": {
        "visibleDeliveries": 1,
        "kind": "media",
        "text": "KOVA_AGENT_MEDIA_REPLY_THREAD_OK",
        "replyTo": "inbound-message",
        "threadId": "kova-model-turn-thread",
        "mediaSource": "/tmp/kova-channel-model-turn-media-reply-thread.png",
        "mediaSourcePolicy": "exact",
        "terminal": true,
        "noDuplicateFinal": true
      },
      "fixtures": {
        "mediaPath": "/tmp/kova-channel-model-turn-media-reply-thread.png"
      },
      "providerRequests": {
        "mode": "exact",
        "expected": 1
      },
      "atoms": [
        { "group": "durable-final", "id": "media" },
        { "group": "durable-final", "id": "reply-to" },
        { "group": "durable-final", "id": "thread" },
        { "group": "workflow", "id": "media-reply-thread-final" },
        { "group": "workflow", "id": "single-inbound-single-final" },
        { "group": "workflow", "id": "final-delivery-receipt-required" },
        { "group": "workflow", "id": "terminal-after-final" }
      ]
    },
    {
      "id": "thread-final",
      "workflow": "final-text-thread",
      "userAction": "user replies in a thread and receives OpenClaw's answer in that thread",
