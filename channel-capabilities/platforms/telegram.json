{
  "schemaVersion": "kova.channelPlatform.v1",
  "id": "telegram",
  "title": "Telegram Channel",
  "adapter": {
    "kind": "bundled",
    "modulePath": "dist/extensions/telegram/channel-plugin-api.js",
    "exportName": "telegramPlugin"
  },
  "sources": [
    "extensions/telegram/src/channel.ts",
    "extensions/telegram/src/channel-actions.ts",
    "extensions/telegram/src/channel-actions.contract.test.ts",
    "extensions/telegram/src/outbound-adapter.ts"
  ],
  "capabilities": {
    "durable-final": [
      "text",
      "media",
      "payload",
      "reply-to",
      "thread",
      "silent",
      "message-sending-hooks",
      "batch"
    ],
    "ack": [
      "after-receive-record",
      "after-agent-dispatch"
    ],
    "live-preview": [
      "draft-preview",
      "preview-finalization",
      "progress-updates"
    ],
    "live-finalizer": [
      "final-edit",
      "normal-fallback",
      "preview-receipt",
      "retain-on-ambiguous-failure"
    ],
    "native-platform": [
      "action-send",
      "action-poll",
      "action-react",
      "action-delete",
      "action-edit",
      "action-topic-create",
      "action-topic-edit",
      "delivery-pin",
      "presentation"
    ]
  }
}
