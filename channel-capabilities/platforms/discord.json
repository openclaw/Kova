{
  "schemaVersion": "kova.channelPlatform.v1",
  "id": "discord",
  "title": "Discord Channel",
  "adapter": {
    "kind": "external",
    "packageName": "@openclaw/discord",
    "pluginId": "discord",
    "localBuildPath": "dist/extensions/discord",
    "modulePath": "dist/channel-plugin-api.js",
    "exportName": "discordPlugin"
  },
  "sources": [
    "extensions/discord/src/channel.ts",
    "extensions/discord/src/outbound-adapter.ts"
  ],
  "capabilities": {
    "durable-final": [
      "text",
      "media",
      "payload",
      "reply-to",
      "thread",
      "silent",
      "message-sending-hooks"
    ],
    "ack": [
      "manual"
    ],
    "live-preview": [
      "draft-preview",
      "preview-finalization",
      "progress-updates"
    ],
    "live-finalizer": [
      "final-edit",
      "normal-fallback",
      "discard-pending"
    ]
  }
}
