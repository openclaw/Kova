    "source-visible-delivery.media.message-tool-only": {
      "visibleDeliveries": 2,
      "textDeliveryIndex": 0,
      "mediaDeliveryIndex": 1
    },
    "source-visible-delivery.media-thread.message-tool-only": {
      "visibleDeliveries": 2,
      "textDeliveryIndex": 0,
      "mediaDeliveryIndex": 1
    }
  },
  "deterministicShim": {
    "conversationId": "channel:123456",
    "threadId": "thread-1",
    "replyToId": "reply-1",
    "accountId": "default",
    "platform": {
      "resultMessageIdPrefix": "discord",
      "resultTargetField": "channelId",
      "replyOptionField": "replyTo",
      "replyOptionValue": "reply-1",
      "threadTarget": "channel:thread-1"
    }
  },
  "capabilities": [
