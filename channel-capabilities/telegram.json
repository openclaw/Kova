    "background-artifact-completion.music.message-tool-only",
    "completion-handoff.image.generated-direct",
    "completion-handoff.image.generated-thread"
  ],
  "deterministicShim": {
    "conversationId": "12345",
    "threadId": "12",
    "replyToId": "900",
