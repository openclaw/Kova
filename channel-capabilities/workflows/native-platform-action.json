      },
      "sourceReplyDeliveryMode": "message_tool_only",
      "expects": {
        "visibleDeliveries": 0,
        "nativeActions": {
          "action-react": 1
        },
        "terminal": true
      },
      "atoms": [
        {
          "group": "native-platform",
          "id": "action-react"
        }
      ]
    },
