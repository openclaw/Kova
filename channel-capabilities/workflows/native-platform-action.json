{
  "schemaVersion": "kova.channelWorkflowFamily.v1",
  "id": "native-platform-action",
  "title": "Native Platform Message Action",
  "userAction": "user asks OpenClaw to use a channel-native message action from the current conversation",
  "openclawSurface": "channel inbound message with native channel action dispatch",
  "ownerArea": "OpenClaw native channel action runtime",
  "sourceRefs": [
    "src/channels/plugins/message-action-discovery.ts",
    "src/channels/plugins/message-capabilities.ts",
    "src/agents/pi-embedded-runner/run/message-tool-terminal.ts"
  ],
  "contentKinds": [
    "text",
    "poll",
    "reaction",
    "topic",
    "presentation"
  ],
  "routeKinds": [
    "direct",
    "thread",
    "reply"
  ],
  "deliveryModes": [
    "native-action",
    "message-tool-only-source-delivery"
  ],
  "lifecycles": [
    "success",
    "terminal"
  ],
  "atoms": [
    {
      "group": "native-platform",
      "id": "action-send"
    },
    {
      "group": "native-platform",
      "id": "action-poll"
    },
    {
      "group": "native-platform",
      "id": "action-react"
    },
    {
      "group": "native-platform",
      "id": "action-delete"
    },
    {
      "group": "native-platform",
