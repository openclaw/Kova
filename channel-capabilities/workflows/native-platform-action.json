    },
    {
      "group": "native-platform",
      "id": "delivery-pin"
    },
    {
      "group": "native-platform",
      "id": "presentation"
    }
  ],
  "cases": [
    {
      "id": "native-action.send.presentation-pin",
      "workflow": "native-platform-action",
      "matrix": {
        "content": "presentation",
        "route": "direct",
        "delivery": "native-action",
        "lifecycle": "success"
      },
      "userAction": "user asks OpenClaw to send a status card and pin it in the current chat",
      "openclawSurface": "channel inbound direct message with native send action, presentation payload, and delivery pin",
      "prompt": "Send a launch status card and pin it here.",
      "providerScript": {
        "toolCalls": [
          {
            "name": "message",
            "arguments": {
              "action": "send",
              "message": "KOVA_NATIVE_PRESENTATION_PIN_OK",
              "presentation": {
                "blocks": [
                  {
                    "type": "text",
                    "text": "KOVA_NATIVE_PRESENTATION_PIN_OK"
                  }
                ]
              },
              "delivery": {
                "pin": {
                  "enabled": true,
                  "notify": false
                }
              }
            }
          }
        ],
        "finalText": "NO_REPLY"
      },
      "sourceReplyDeliveryMode": "message_tool_only",
      "expects": {
        "visibleDeliveries": 1,
        "kind": "text",
        "text": "KOVA_NATIVE_PRESENTATION_PIN_OK",
        "nativeActions": {
          "action-send": 1,
          "delivery-pin": 1
        },
        "terminal": true,
        "noDuplicateFinal": true
      },
      "atoms": [
        {
          "group": "native-platform",
          "id": "action-send"
        },
        {
          "group": "native-platform",
          "id": "presentation"
        },
        {
          "group": "native-platform",
          "id": "delivery-pin"
        }
      ]
    },
    {
      "id": "native-action.poll",
      "workflow": "native-platform-action",
      "matrix": {
        "content": "poll",
        "route": "direct",
        "delivery": "native-action",
        "lifecycle": "success"
      },
      "userAction": "user asks OpenClaw to create a poll in the current chat",
      "openclawSurface": "channel inbound direct message with native poll action",
      "prompt": "Create a launch readiness poll here.",
      "providerScript": {
        "toolCalls": [
          {
            "name": "message",
            "arguments": {
              "action": "poll",
              "question": "Is the launch ready?",
              "answers": [
                "Yes",
                "No"
              ],
              "allowMultiselect": false,
              "isAnonymous": false
            }
          }
        ],
        "finalText": "NO_REPLY"
      },
      "sourceReplyDeliveryMode": "message_tool_only",
      "expects": {
        "visibleDeliveries": 1,
        "kind": "poll",
        "text": "Is the launch ready?",
        "nativeActions": {
          "action-poll": 1
        },
        "terminal": true,
        "noDuplicateFinal": true
      },
      "atoms": [
        {
          "group": "durable-final",
          "id": "poll"
        },
        {
          "group": "native-platform",
          "id": "action-poll"
        }
      ]
    },
    {
