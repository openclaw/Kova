    {
      "id": "silent-final",
      "workflow": "source-visible-delivery-silent",
      "matrix": {
        "content": "text",
        "route": "direct",
        "delivery": "message-tool-only-source-delivery",
        "lifecycle": "success"
      },
      "userAction": "user triggers a quiet channel response and OpenClaw sends it without noisy notification intent",
      "openclawSurface": "channel inbound direct message with source conversation delivery",
      "prompt": "Send a quiet deployment reminder.",
      "providerScript": {
        "toolCalls": [
          {
            "name": "message",
            "arguments": {
              "action": "send",
              "message": "KOVA_AGENT_SILENT_OK",
              "silent": true
            }
          }
        ],
        "finalText": "KOVA_SOURCE_DELIVERY_PRIVATE_DONE"
      },
      "sourceReplyDeliveryMode": "message_tool_only",
      "expects": {
        "visibleDeliveries": 1,
        "kind": "text",
        "text": "KOVA_AGENT_SILENT_OK",
        "silent": true,
        "terminal": true
      },
      "providerRequests": {
        "mode": "minimum",
        "min": 1
      },
      "atoms": [
        {
          "group": "durable-final",
          "id": "silent"
        }
      ]
    },
